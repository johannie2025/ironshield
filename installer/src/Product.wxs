<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="IronShield FIM"
           Manufacturer="Wise Design"
           Version="$(var.ProductVersion)"
           UpgradeCode="4E2B9E2F-8C1D-4E1B-9B2E-1A6F0C7D5A21"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="Une version plus récente d'IronShield FIM est déjà installée." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="IronShield FIM">
        <Directory Id="AGENTDIR" Name="agent" />
        <Directory Id="GUIDIR" Name="gui" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ShortcutFolder" Name="IronShield FIM" />
    </StandardDirectory>

    <!-- Binaires de l'agent + de l'updater -->
    <ComponentGroup Id="AgentComponents" Directory="AGENTDIR">
      <Component Id="AgentExe" Guid="*">
        <File Id="AgentExeFile" Source="$(var.AgentExePath)" KeyPath="yes" />
      </Component>
      <Component Id="UpdaterExe" Guid="*">
        <File Id="UpdaterExeFile" Source="$(var.UpdaterExePath)" KeyPath="yes" />
      </Component>
      <Component Id="ChecksumsFile" Guid="*">
        <File Id="Sha256SumsFile" Source="$(var.Sha256SumsPath)" KeyPath="yes" />
      </Component>
      <Component Id="VersionFile" Guid="*">
        <File Id="VersionFileRef" Source="$(var.VersionPath)" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Interface graphique (Tauri) -->
    <ComponentGroup Id="GuiComponents" Directory="GUIDIR">
      <Component Id="GuiExe" Guid="*">
        <File Id="GuiExeFile" Source="$(var.GuiExePath)" KeyPath="yes" />
        <Shortcut Id="GuiShortcut"
                  Directory="ShortcutFolder"
                  Name="IronShield FIM"
                  WorkingDirectory="GUIDIR"
                  Advertise="yes" />
      </Component>
    </ComponentGroup>

    <!-- Marqueur de registre : confirme que l'installation des fichiers a
         réussi. L'enregistrement des tâches planifiées se fait via une
         étape manuelle (register-tasks.cmd, à exécuter en administrateur
         après installation) plutôt que par CustomAction MSI automatique :
         plusieurs tentatives de CustomAction (schtasks.exe en ligne, puis
         scripts .cmd via cmd.exe) ont échoué avec l'erreur générique MSI
         "a program required for this install to complete could not be
         run" sans qu'il soit possible de diagnostiquer la cause exacte
         sans un environnement WiX pour itérer directement. Un installeur
         fiable avec une étape manuelle documentée est préférable à un
         installeur qui échoue systématiquement.
    -->
    <Component Id="ScheduledTaskMarker" Directory="AGENTDIR" Guid="*">
      <RegistryValue Root="HKLM"
                      Key="Software\WiseDesign\IronShieldFIM"
                      Name="FilesInstalled"
                      Type="integer"
                      Value="1"
                      KeyPath="yes" />
    </Component>

    <!-- Scripts embarqués : présents dans le dossier d'installation pour
         que l'utilisateur/admin puisse les exécuter manuellement (clic
         droit > Exécuter en tant qu'administrateur) après l'installation. -->
    <Component Id="RegisterTasksScript" Directory="AGENTDIR" Guid="*">
      <File Id="RegisterTasksScriptFile" Source="$(var.RegisterTasksScriptPath)" KeyPath="yes" />
    </Component>
    <Component Id="UnregisterTasksScript" Directory="AGENTDIR" Guid="*">
      <File Id="UnregisterTasksScriptFile" Source="$(var.UnregisterTasksScriptPath)" KeyPath="yes" />
    </Component>
    <Component Id="PostInstallReadme" Directory="AGENTDIR" Guid="*">
      <File Id="PostInstallReadmeFile" Source="$(var.PostInstallReadmePath)" KeyPath="yes" />
    </Component>

    <Feature Id="MainFeature" Title="IronShield FIM" Level="1">
      <ComponentGroupRef Id="AgentComponents" />
      <ComponentGroupRef Id="GuiComponents" />
      <ComponentRef Id="ScheduledTaskMarker" />
      <ComponentRef Id="RegisterTasksScript" />
      <ComponentRef Id="UnregisterTasksScript" />
      <ComponentRef Id="PostInstallReadme" />
    </Feature>

  </Package>
</Wix>
