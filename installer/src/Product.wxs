<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="IronShield FIM"
           Manufacturer="Wise Design"
           Version="$(var.ProductVersion)"
           UpgradeCode="4E2B9E2F-8C1D-4E1B-9B2E-1A6F0C7D5A21"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="Une version plus récente d'IronShield FIM est déjà installée." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="IronShield FIM">
        <Directory Id="AGENTDIR" Name="agent" />
        <Directory Id="GUIDIR" Name="gui" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ShortcutFolder" Name="IronShield FIM" />
    </StandardDirectory>

    <!-- Binaires de l'agent + de l'updater -->
    <ComponentGroup Id="AgentComponents" Directory="AGENTDIR">
      <Component Id="AgentExe" Guid="*">
        <File Id="AgentExeFile" Source="$(var.AgentExePath)" KeyPath="yes" />
      </Component>
      <Component Id="UpdaterExe" Guid="*">
        <File Id="UpdaterExeFile" Source="$(var.UpdaterExePath)" KeyPath="yes" />
      </Component>
      <Component Id="ChecksumsFile" Guid="*">
        <File Id="Sha256SumsFile" Source="$(var.Sha256SumsPath)" KeyPath="yes" />
      </Component>
      <Component Id="VersionFile" Guid="*">
        <File Id="VersionFileRef" Source="$(var.VersionPath)" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Interface graphique (Tauri) -->
    <ComponentGroup Id="GuiComponents" Directory="GUIDIR">
      <Component Id="GuiExe" Guid="*">
        <File Id="GuiExeFile" Source="$(var.GuiExePath)" KeyPath="yes" />
        <Shortcut Id="GuiShortcut"
                  Directory="ShortcutFolder"
                  Name="IronShield FIM"
                  WorkingDirectory="GUIDIR"
                  Advertise="yes" />
      </Component>
    </ComponentGroup>

    <!-- Marqueur de registre pour le suivi d'installation des tâches planifiées -->
    <Component Id="ScheduledTaskMarker" Directory="AGENTDIR" Guid="*">
      <RegistryValue Root="HKLM"
                      Key="Software\WiseDesign\IronShieldFIM"
                      Name="ScheduledTasksInstalled"
                      Type="integer"
                      Value="1"
                      KeyPath="yes" />
    </Component>

    <!--
      Enregistrement des tâches planifiées via schtasks.exe (fiable et
      indépendant des extensions WiX). L'agent tourne en continu (redémarré
      au boot), l'updater est vérifié toutes les 6 heures.
      Suppression symétrique à la désinstallation.
    -->
    <CustomAction Id="RegisterAgentTask"
                  ExeCommand="schtasks.exe /Create /F /SC ONSTART /RL HIGHEST /TN &quot;IronShieldFIM-Agent&quot; /TR &quot;\&quot;[AGENTDIR]ironshield-agent.exe\&quot;&quot;"
                  Directory="AGENTDIR"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="RegisterUpdaterTask"
                  ExeCommand="schtasks.exe /Create /F /SC HOURLY /MO 6 /RL HIGHEST /TN &quot;IronShieldFIM-Updater&quot; /TR &quot;\&quot;[AGENTDIR]ironshield-updater.exe\&quot;&quot;"
                  Directory="AGENTDIR"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="StartAgentTask"
                  ExeCommand="schtasks.exe /Run /TN &quot;IronShieldFIM-Agent&quot;"
                  Directory="AGENTDIR"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="UnregisterAgentTask"
                  ExeCommand="schtasks.exe /Delete /F /TN &quot;IronShieldFIM-Agent&quot;"
                  Directory="AGENTDIR"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="UnregisterUpdaterTask"
                  ExeCommand="schtasks.exe /Delete /F /TN &quot;IronShieldFIM-Updater&quot;"
                  Directory="AGENTDIR"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="RegisterAgentTask" After="InstallFiles" Condition="NOT Installed" />
      <Custom Action="RegisterUpdaterTask" After="RegisterAgentTask" Condition="NOT Installed" />
      <Custom Action="StartAgentTask" After="RegisterUpdaterTask" Condition="NOT Installed" />
      <Custom Action="UnregisterAgentTask" Before="RemoveFiles" Condition="Installed AND (REMOVE=&quot;ALL&quot;)" />
      <Custom Action="UnregisterUpdaterTask" After="UnregisterAgentTask" Condition="Installed AND (REMOVE=&quot;ALL&quot;)" />
    </InstallExecuteSequence>

    <Feature Id="MainFeature" Title="IronShield FIM" Level="1">
      <ComponentGroupRef Id="AgentComponents" />
      <ComponentGroupRef Id="GuiComponents" />
      <ComponentRef Id="ScheduledTaskMarker" />
    </Feature>

  </Package>
</Wix>
